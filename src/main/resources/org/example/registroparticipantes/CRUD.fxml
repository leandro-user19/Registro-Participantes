<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="600.0" prefWidth="1000.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.registroparticipantes.HelloController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <VBox prefWidth="380.0" spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">
        <Label text="Registro de Participantes">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <VBox spacing="3.0">
            <Label text="ID (Automático):" />
            <TextField fx:id="txtId" disable="true" editable="false" promptText="ID Autogenerado" />
        </VBox>

        <VBox spacing="3.0">
            <Label text="Cédula:" />
            <TextField fx:id="txtCedula" promptText="Ej: 1723456789" />
        </VBox>

        <HBox spacing="10.0">
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Nombre:" />
                <TextField fx:id="txtNombre" promptText="Nombres" />
            </VBox>
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Apellido:" />
                <TextField fx:id="txtApellido" promptText="Apellidos" />
            </VBox>
        </HBox>

        <HBox spacing="10.0">
            <VBox prefWidth="80.0" spacing="3.0">
                <Label text="Edad:" />
                <TextField fx:id="txtEdad" promptText="Edad" />
            </VBox>
            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                <Label text="Correo Electrónico:" />
                <TextField fx:id="txtCorreo" promptText="ejemplo@correo.com" />
            </VBox>
        </HBox>

        <VBox spacing="3.0">
            <Label text="Estado Civil:" />
            <ComboBox fx:id="cmbEstadoCivil" prefWidth="380.0" promptText="Seleccione Estado Civil" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Jornada:" />
            <HBox spacing="15.0">
                <children>
                    <RadioButton fx:id="rbMatutina" text="Matutina">
                        <toggleGroup>
                            <ToggleGroup fx:id="tgJornada" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="rbVespertina" text="Vespertina" toggleGroup="$tgJornada" />
                    <RadioButton fx:id="rbNocturna" text="Nocturna" toggleGroup="$tgJornada" />
                </children>
            </HBox>
        </VBox>

        <VBox spacing="3.0">
            <Label text="Categoría:" />
            <ComboBox fx:id="cmbCategoria" prefWidth="380.0" promptText="Seleccione Categoría" />
        </VBox>

        <VBox spacing="3.0" VBox.vgrow="ALWAYS">
            <Label text="Observaciones:" />
            <TextArea fx:id="txtObservaciones" prefHeight="80.0" promptText="Detalles u observaciones adicionales..." wrapText="true" />
        </VBox>

        <HBox alignment="CENTER" spacing="8.0">
            <Button fx:id="btnCrear" onAction="#Crear" prefWidth="85.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar" />
            <Button fx:id="btnActualizar" onAction="#handleActualizar" prefWidth="85.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Modificar" />
            <Button fx:id="btnEliminar" onAction="#handleEliminar" prefWidth="85.0" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Eliminar" />
            <Button fx:id="btnLimpiar" onAction="#Limpiar" prefWidth="85.0" text="Limpiar" />
        </HBox>
    </VBox>

    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label text="Listado de Nadadores Registrados">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <TableView fx:id="tblParticipantes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colCedula" prefWidth="90.0" text="Cédula" />
                <TableColumn fx:id="colNombre" prefWidth="100.0" text="Nombre" />
                <TableColumn fx:id="colApellido" prefWidth="100.0" text="Apellido" />
                <TableColumn fx:id="colEdad" prefWidth="50.0" text="Edad" />
                <TableColumn fx:id="colCorreo" prefWidth="120.0" text="Correo" />
                <TableColumn fx:id="colEstadoCivil" prefWidth="80.0" text="Est. Civil" />
                <TableColumn fx:id="colJornada" prefWidth="80.0" text="Jornada" />
                <TableColumn fx:id="colCategoria" prefWidth="90.0" text="Categoría" />
            </columns>
        </TableView>
    </VBox>
</HBox>
